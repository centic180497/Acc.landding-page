@import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&display=swap');

/* ==========================================
   DESIGN SYSTEM & VARIABLES
   ========================================== */
:root {
  --primary: #7a2828;
  --primary-dark: #5d1c1c;
  --primary-deep: #3d1010;
  --primary-light: #fdf5f5;
  --primary-soft: #f7e6e6;
  --primary-rgb: 122, 40, 40;
  --secondary: #d4af37;
  --secondary-soft: #f3e3a8;
  --secondary-hover: #bda02e;
  --dark: #1e1b1b;
  --muted: #5a5454;
  --light: #ffffff;
  --bg-gray: #faf6f6;
  --bg-cream: #fbf3ee;
  --border: #ead8d8;
  --success: #2e7d32;

  --font-family: 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  --font-serif: 'Roboto', 'Helvetica Neue', Arial, sans-serif;

  --shadow-sm: 0 4px 12px rgba(122, 40, 40, 0.08);
  --shadow-md: 0 14px 32px rgba(122, 40, 40, 0.12);
  --shadow-lg: 0 22px 48px rgba(122, 40, 40, 0.18);
  --shadow-gold: 0 12px 28px rgba(212, 175, 55, 0.28);
  --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  --radius-sm: 10px;
  --radius-md: 18px;
  --radius-lg: 28px;
}

/* ==========================================
   RESET & GLOBAL STYLES
   ========================================== */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
  font-size: 16px;
}

body {
  font-family: var(--font-family);
  background-color: var(--light);
  color: var(--dark);
  line-height: 1.65;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

img {
  max-width: 100%;
  height: auto;
  display: block;
}

a {
  text-decoration: none;
  color: inherit;
  transition: var(--transition);
}

button, input, textarea, select {
  font-family: inherit;
  border: none;
  outline: none;
}

/* Custom Scrollbar */
::-webkit-scrollbar { width: 10px; }
::-webkit-scrollbar-track { background: var(--bg-gray); }
::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, var(--primary), var(--primary-dark));
  border-radius: 5px;
}
::-webkit-scrollbar-thumb:hover { background: var(--primary-deep); }

/* ==========================================
   REUSABLE UTILITIES
   ========================================== */
.container {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

.section {
  padding: 56px 0;
  position: relative;
}

.section + .section { padding-top: 40px; }

.section:nth-child(even) {
  background-color: var(--bg-gray);
  background-image:
    radial-gradient(circle at 0% 0%, rgba(122, 40, 40, 0.04), transparent 50%),
    radial-gradient(circle at 100% 100%, rgba(212, 175, 55, 0.05), transparent 50%);
}

.text-center { text-align: center; }

.section-tag {
  display: inline-block;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: var(--light);
  font-weight: 700;
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 2.2px;
  padding: 9px 22px;
  border-radius: 50px;
  margin-bottom: 18px;
  box-shadow: 0 6px 18px rgba(122, 40, 40, 0.28);
}

.section-title {
  font-family: var(--font-serif);
  font-size: 2.4rem;
  font-weight: 800;
  color: var(--primary);
  margin-bottom: 18px;
  line-height: 1.25;
  letter-spacing: -0.5px;
}

.section-desc {
  max-width: 740px;
  margin: 0 auto 50px auto;
  color: var(--muted);
  font-size: 1.08rem;
  line-height: 1.75;
}

.section-visual-card {
  background: linear-gradient(145deg, #ffffff 0%, #fffafa 100%);
  border: 1px solid rgba(122, 40, 40, 0.12);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-md);
  overflow: hidden;
}

.section-visual-card img {
  width: 100%;
  aspect-ratio: 19 / 8.2;
  object-fit: contain;
  display: block;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 15px 30px;
  border-radius: var(--radius-sm);
  font-weight: 700;
  font-size: 1rem;
  cursor: pointer;
  transition: var(--transition);
  text-align: center;
  border: 2px solid transparent;
}

.btn i { font-size: 1.05em; }

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: var(--light);
  box-shadow: 0 8px 22px rgba(122, 40, 40, 0.35);
}

.btn-primary:hover {
  background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary-deep) 100%);
  transform: translateY(-3px);
  box-shadow: 0 12px 28px rgba(122, 40, 40, 0.45);
}

.btn-secondary {
  background: linear-gradient(135deg, var(--secondary) 0%, var(--secondary-hover) 100%);
  color: var(--primary-deep);
  box-shadow: var(--shadow-gold);
}

.btn-secondary:hover {
  transform: translateY(-3px);
  box-shadow: 0 14px 32px rgba(212, 175, 55, 0.45);
}

.btn-outline {
  background-color: transparent;
  color: var(--primary);
  border: 2px solid var(--primary);
}

.btn-outline:hover {
  background-color: var(--primary);
  color: var(--light);
  transform: translateY(-3px);
  box-shadow: 0 10px 24px rgba(122, 40, 40, 0.28);
}

/* ==========================================
   ANIMATIONS
   ========================================== */
.animate-on-scroll {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}

.animate-on-scroll.animated {
  opacity: 1;
  transform: translateY(0);
}

.delay-100 { transition-delay: 0.1s; }
.delay-150 { transition-delay: 0.15s; }
.delay-200 { transition-delay: 0.2s; }
.delay-300 { transition-delay: 0.3s; }
.delay-400 { transition-delay: 0.4s; }
.delay-500 { transition-delay: 0.5s; }

/* ==========================================
   HERO SECTION
   ========================================== */
.hero {
  padding: 110px 0 100px 0;
  background:
    linear-gradient(135deg, rgba(61, 16, 16, 0.78) 0%, rgba(122, 40, 40, 0.55) 55%, rgba(212, 175, 55, 0.20) 100%),
    url('https://congtyluatacc.vn/wp-content/uploads/2026/06/bg-thanh-lap-cong-ty.jpg') no-repeat center center / cover;
  position: relative;
  overflow: hidden;
  color: var(--light);
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 80% 20%, rgba(212, 175, 55, 0.15), transparent 50%);
  pointer-events: none;
}

.hero::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 80px;
  background: linear-gradient(to top, var(--light), transparent);
  pointer-events: none;
}

.hero-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.12fr) minmax(360px, 0.88fr);
  gap: 56px;
  align-items: center;
  position: relative;
  z-index: 2;
}

.hero-tagline {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background-color: rgba(212, 175, 55, 0.18);
  color: var(--secondary-soft);
  padding: 10px 18px;
  border-radius: 50px;
  font-size: 0.88rem;
  font-weight: 700;
  margin-bottom: 24px;
  border: 1px solid rgba(212, 175, 55, 0.4);
  backdrop-filter: blur(6px);
}

.hero-tagline i { color: var(--secondary); font-size: 1rem; }

.hero-title {
  font-family: var(--font-serif);
  font-size: 3.2rem;
  font-weight: 800;
  line-height: 1.2;
  color: var(--light);
  margin-bottom: 22px;
  text-shadow: 0 4px 18px rgba(0, 0, 0, 0.25);
}

.hero-title span {
  color: var(--secondary);
  display: inline-block;
}

.hero-desc {
  font-size: 1.12rem;
  color: rgba(255, 255, 255, 0.92);
  margin-bottom: 32px;
  line-height: 1.75;
  max-width: 720px;
}

.hero-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  margin-bottom: 40px;
}

.hero-buttons .btn-primary {
  background: linear-gradient(135deg, var(--secondary) 0%, var(--secondary-hover) 100%);
  color: var(--primary-deep);
  box-shadow: 0 12px 28px rgba(212, 175, 55, 0.4);
}

.hero-buttons .btn-primary:hover {
  background: linear-gradient(135deg, #e6c354 0%, var(--secondary) 100%);
  box-shadow: 0 16px 36px rgba(212, 175, 55, 0.5);
}

.hero-buttons .btn-secondary {
  background: rgba(255, 255, 255, 0.12);
  color: var(--light);
  border: 2px solid rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(8px);
  box-shadow: none;
}

.hero-buttons .btn-secondary:hover {
  background: rgba(255, 255, 255, 0.22);
  border-color: var(--light);
}

.hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 22px;
  border-top: 1px solid rgba(255, 255, 255, 0.18);
  padding-top: 22px;
}

.badge-item {
  display: flex;
  align-items: center;
  gap: 12px;
}

.badge-icon {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--secondary), var(--secondary-hover));
  color: var(--primary-deep);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.05rem;
  box-shadow: 0 6px 16px rgba(212, 175, 55, 0.4);
}

.badge-text {
  font-size: 0.92rem;
  font-weight: 600;
  color: var(--light);
}

.hero-card-wrapper {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 2;
}

.hero-card {
  background: var(--light);
  border-radius: var(--radius-lg);
  padding: 36px;
  box-shadow: 0 30px 60px rgba(0, 0, 0, 0.25);
  border: 1px solid rgba(255, 255, 255, 0.4);
  position: relative;
  width: 100%;
  max-width: 460px;
  color: var(--dark);
}

.hero-summary-card { overflow: hidden; }

.hero-summary-card::before {
  content: '';
  position: absolute;
  inset: 0 0 auto 0;
  height: 6px;
  background: linear-gradient(90deg, var(--primary), var(--secondary));
}

.hero-summary-header { margin-bottom: 24px; }

.hero-summary-header span {
  display: inline-flex;
  padding: 7px 14px;
  margin-bottom: 12px;
  border-radius: 999px;
  background: var(--primary);
  color: var(--light);
  font-size: 0.74rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 1.2px;
}

.hero-summary-header h3 {
  font-family: var(--font-serif);
  font-size: 1.6rem;
  font-weight: 800;
  color: var(--primary);
  line-height: 1.3;
}

.hero-summary-steps {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.hero-summary-step {
  display: grid;
  grid-template-columns: 52px 1fr;
  gap: 14px;
  padding: 16px;
  border-radius: var(--radius-sm);
  background: var(--bg-gray);
  border: 1px solid var(--border);
  transition: var(--transition);
}

.hero-summary-step:hover {
  background: var(--primary-light);
  border-color: rgba(122, 40, 40, 0.25);
  transform: translateX(4px);
}

.hero-summary-step strong {
  width: 52px;
  height: 52px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: var(--light);
  font-size: 1rem;
  font-weight: 800;
  box-shadow: 0 6px 14px rgba(122, 40, 40, 0.28);
}

.hero-summary-step h4 {
  font-size: 1.02rem;
  color: var(--dark);
  margin-bottom: 4px;
  font-weight: 700;
}

.hero-summary-step p {
  color: var(--muted);
  font-size: 0.92rem;
  line-height: 1.5;
}

.hero-summary-cta {
  width: 100%;
  margin-top: 24px;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
}

.hero-glow {
  position: absolute;
  width: 420px;
  height: 420px;
  background: radial-gradient(circle, rgba(212, 175, 55, 0.25) 0%, rgba(122, 40, 40, 0.1) 50%, transparent 100%);
  border-radius: 50%;
  top: -60px;
  right: -80px;
  filter: blur(40px);
  z-index: 1;
  pointer-events: none;
}

/* ==========================================
   SECTION 1: KHÁI NIỆM
   ========================================== */
.concept-box {
  background: linear-gradient(145deg, #ffffff 0%, #fffafa 100%);
  border-radius: var(--radius-lg);
  padding: 48px;
  box-shadow: var(--shadow-md);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 44px;
  align-items: center;
  border: 1px solid var(--border);
  position: relative;
  overflow: hidden;
}

.concept-box::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6px;
  background: linear-gradient(180deg, var(--primary), var(--secondary));
}

.concept-content h3 {
  font-family: var(--font-serif);
  font-size: 1.85rem;
  color: var(--primary);
  margin-bottom: 20px;
  font-weight: 800;
  line-height: 1.3;
}

.concept-content p {
  color: var(--muted);
  margin-bottom: 16px;
  font-size: 1.05rem;
  line-height: 1.8;
}

.concept-content strong { color: var(--primary); font-weight: 700; }

.concept-image-container {
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(135deg, var(--primary-light), #fff7df);
  border-radius: var(--radius-md);
  padding: 24px;
}

/* ==========================================
   SECTION 2: KHÓ KHĂN
   ========================================== */
.difficulties-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 24px;
}

.difficulty-card {
  background: var(--light);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 32px 26px;
  transition: var(--transition);
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.difficulty-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 4px;
  background: linear-gradient(90deg, var(--primary), var(--secondary));
  transform: scaleX(0);
  transform-origin: left;
  transition: var(--transition);
}

.difficulty-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-lg);
  border-color: rgba(122, 40, 40, 0.25);
}

.difficulty-card:hover::before { transform: scaleX(1); }

.difficulty-icon {
  width: 60px;
  height: 60px;
  border-radius: var(--radius-sm);
  background: linear-gradient(135deg, var(--primary-light), var(--primary-soft));
  color: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.6rem;
  margin-bottom: 22px;
  border: 1px solid rgba(122, 40, 40, 0.15);
  transition: var(--transition);
}

.difficulty-card:hover .difficulty-icon {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: var(--light);
  transform: scale(1.05) rotate(-4deg);
  box-shadow: 0 8px 18px rgba(122, 40, 40, 0.32);
}

.difficulty-title {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--dark);
  line-height: 1.5;
}

/* ==========================================
   SECTION 3: DỊCH VỤ TRỌN GÓI
   ========================================== */
.service-showcase {
  display: flex;
  flex-direction: column;
  gap: 28px;
}

.service-feature-card {
  display: grid;
  grid-template-columns: minmax(300px, 0.9fr) minmax(0, 1.1fr);
  gap: 32px;
  align-items: center;
  padding: 36px;
  border-radius: var(--radius-lg);
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  border: 1px solid rgba(212, 175, 55, 0.3);
  box-shadow: var(--shadow-lg);
  color: var(--light);
  position: relative;
  overflow: hidden;
}

.service-feature-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(212, 175, 55, 0.18), transparent 60%);
  pointer-events: none;
}

.service-feature-visual {
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.15);
  overflow: hidden;
  backdrop-filter: blur(6px);
  position: relative;
  z-index: 1;
}

.service-feature-visual img {
  width: 100%;
  aspect-ratio: 19 / 8.5;
  object-fit: contain;
  display: block;
}

.service-feature-content {
  position: relative;
  z-index: 1;
}

.service-feature-content span {
  display: inline-flex;
  padding: 7px 14px;
  margin-bottom: 14px;
  border-radius: 999px;
  background: var(--secondary);
  color: var(--primary-deep);
  font-size: 0.76rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 1.2px;
}

.service-feature-content h3 {
  font-family: var(--font-serif);
  font-size: 1.85rem;
  color: var(--light);
  line-height: 1.3;
  margin-bottom: 14px;
}

.service-feature-content p {
  color: rgba(255, 255, 255, 0.88);
  font-size: 1.02rem;
  line-height: 1.75;
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 22px;
}

.service-card {
  background: var(--light);
  border-radius: var(--radius-md);
  padding: 28px 24px;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--border);
  display: block;
  transition: var(--transition);
  min-height: 240px;
  position: relative;
  overflow: hidden;
}

.service-card::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 3px;
  background: linear-gradient(90deg, var(--primary), var(--secondary));
  transform: scaleX(0);
  transform-origin: left;
  transition: var(--transition);
}

.service-card:hover {
  box-shadow: var(--shadow-lg);
  border-color: rgba(122, 40, 40, 0.22);
  transform: translateY(-5px);
}

.service-card:hover::after { transform: scaleX(1); }

.service-card-icon {
  width: 58px;
  height: 58px;
  min-width: 58px;
  border-radius: var(--radius-sm);
  background: linear-gradient(135deg, var(--primary-light), var(--primary-soft));
  color: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.55rem;
  border: 1px solid rgba(122, 40, 40, 0.12);
  transition: var(--transition);
  margin-bottom: 18px;
}

.service-card:hover .service-card-icon {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: var(--light);
  transform: rotate(-6deg) scale(1.05);
}

.service-card-content h3 {
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 10px;
  line-height: 1.35;
}

.service-card-content p {
  font-size: 0.95rem;
  color: var(--muted);
  line-height: 1.6;
}

.service-cta-block {
  margin-top: 36px;
  background: linear-gradient(135deg, var(--primary-light) 0%, #fff7df 100%);
  border: 1px solid rgba(122, 40, 40, 0.18);
  border-radius: var(--radius-md);
  padding: 28px 32px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 22px;
  flex-wrap: wrap;
  box-shadow: var(--shadow-sm);
}

.service-cta-text {
  font-size: 1.08rem;
  font-weight: 600;
  color: var(--primary);
  display: inline-flex;
  align-items: center;
  gap: 12px;
}

.service-cta-text i { color: var(--secondary); font-size: 1.4rem; }

/* ==========================================
   SECTION 4: TIMELINE
   ========================================== */
.timeline {
  position: relative;
  max-width: 920px;
  margin: 0 auto;
}

.process-visual {
  width: min(100%, 880px);
  margin: -10px auto 48px auto;
}

.timeline::after {
  content: '';
  position: absolute;
  width: 4px;
  background: linear-gradient(180deg, var(--primary), var(--secondary));
  top: 0;
  bottom: 0;
  left: 50%;
  margin-left: -2px;
  border-radius: 4px;
}

.timeline-item {
  padding: 12px 44px;
  position: relative;
  width: 50%;
}

.timeline-item::after {
  content: '';
  position: absolute;
  width: 26px;
  height: 26px;
  right: -13px;
  background: var(--light);
  border: 4px solid var(--primary);
  top: 28px;
  border-radius: 50%;
  z-index: 1;
  transition: var(--transition);
  box-shadow: 0 4px 12px rgba(122, 40, 40, 0.25);
}

.left { left: 0; }
.right { left: 50%; }
.right::after { left: -13px; }

.timeline-content {
  padding: 28px;
  background: var(--light);
  position: relative;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-md);
  border: 1px solid var(--border);
  transition: var(--transition);
}

.timeline-item:hover .timeline-content {
  box-shadow: var(--shadow-lg);
  border-color: rgba(122, 40, 40, 0.25);
  transform: translateY(-4px);
}

.timeline-item:hover::after {
  background: var(--secondary);
  border-color: var(--primary);
  transform: scale(1.15);
}

.timeline-step {
  display: inline-block;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: var(--light);
  font-weight: 700;
  font-size: 0.78rem;
  padding: 5px 14px;
  border-radius: 50px;
  margin-bottom: 14px;
  text-transform: uppercase;
  letter-spacing: 1.2px;
  box-shadow: 0 4px 12px rgba(122, 40, 40, 0.28);
}

.timeline-content h3 {
  font-family: var(--font-serif);
  font-size: 1.3rem;
  font-weight: 800;
  color: var(--primary);
  margin-bottom: 12px;
}

.timeline-content p {
  color: var(--muted);
  font-size: 0.98rem;
  line-height: 1.65;
}

/* ==========================================
   SECTION 5: PRICING
   ========================================== */
.pricing-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
  gap: 32px;
  max-width: 980px;
  margin: 0 auto;
}

.pricing-card {
  background: var(--light);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border);
  padding: 40px 32px;
  position: relative;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-sm);
  transition: var(--transition);
  overflow: hidden;
}

.pricing-card.featured {
  border: 2px solid var(--primary);
  box-shadow: var(--shadow-lg);
  transform: scale(1.03);
  background: linear-gradient(145deg, #ffffff 0%, var(--primary-light) 100%);
}

.pricing-card.featured::before {
  content: '';
  position: absolute;
  inset: 0 0 auto 0;
  height: 6px;
  background: linear-gradient(90deg, var(--primary), var(--secondary));
}

.pricing-ribbon {
  position: absolute;
  top: 24px;
  right: -38px;
  background: linear-gradient(135deg, var(--secondary), var(--secondary-hover));
  color: var(--primary-deep);
  font-size: 0.78rem;
  font-weight: 800;
  padding: 5px 38px;
  transform: rotate(45deg);
  text-transform: uppercase;
  letter-spacing: 1.2px;
  box-shadow: 0 4px 12px rgba(212, 175, 55, 0.4);
}

.pricing-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-lg);
}

.pricing-card.featured:hover {
  transform: scale(1.03) translateY(-6px);
}

.pricing-header {
  margin-bottom: 26px;
  text-align: center;
  border-bottom: 2px dashed var(--border);
  padding-bottom: 26px;
}

.pricing-header h3 {
  font-family: var(--font-serif);
  font-size: 1.55rem;
  font-weight: 800;
  color: var(--primary);
  margin-bottom: 12px;
}

.pricing-price {
  font-size: 2.4rem;
  font-weight: 900;
  color: var(--dark);
  font-family: var(--font-serif);
}

.pricing-price span {
  font-size: 1rem;
  font-weight: 500;
  color: var(--muted);
  font-family: var(--font-family);
}

.pricing-features {
  list-style: none;
  margin-bottom: 32px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  flex-grow: 1;
}

.pricing-features li {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  font-size: 0.96rem;
  color: var(--muted);
  line-height: 1.55;
}

.pricing-features li i {
  color: var(--success);
  margin-top: 4px;
  width: 18px;
  font-size: 1rem;
  flex-shrink: 0;
}

.pricing-features li.strong {
  color: var(--dark);
  font-weight: 600;
}

/* ==========================================
   SECTION 6: TIME
   ========================================== */
.time-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 26px;
}

.time-card {
  background: var(--light);
  border-radius: var(--radius-lg);
  padding: 36px 28px;
  text-align: center;
  border: 1px solid var(--border);
  box-shadow: var(--shadow-sm);
  transition: var(--transition);
  position: relative;
  overflow: hidden;
}

.time-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, transparent 60%, rgba(122, 40, 40, 0.05));
  pointer-events: none;
}

.time-card:hover {
  border-color: rgba(122, 40, 40, 0.25);
  transform: translateY(-6px);
  box-shadow: var(--shadow-md);
}

.time-circle {
  width: 88px;
  height: 88px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-light), var(--primary-soft));
  color: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.85rem;
  font-weight: 900;
  margin: 0 auto 24px auto;
  border: 3px solid var(--primary);
  position: relative;
  transition: var(--transition);
  font-family: var(--font-serif);
}

.time-card:hover .time-circle {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: var(--light);
  transform: scale(1.08);
  box-shadow: 0 12px 26px rgba(122, 40, 40, 0.35);
}

.time-card h3 {
  font-size: 1.22rem;
  font-weight: 700;
  color: var(--dark);
  margin-bottom: 12px;
}

.time-card p {
  color: var(--muted);
  font-size: 0.95rem;
  line-height: 1.6;
}

/* ==========================================
   SECTION 7-8: DOCS & CONDITIONS
   ========================================== */
.docs-conditions-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 30px;
  align-items: stretch;
  max-width: 1120px;
  margin: 0 auto;
}

.docs-section-heading .section-desc { margin-bottom: 40px; }

.docs-box,
.conditions-box {
  background: var(--light);
  border-radius: var(--radius-lg);
  padding: 36px;
  box-shadow: var(--shadow-md);
  border: 1px solid var(--border);
  position: relative;
  overflow: hidden;
}

.docs-box {
  border-top: 5px solid var(--primary);
  background: linear-gradient(180deg, #ffffff 0%, var(--primary-light) 100%);
}

.conditions-box {
  border-top: 5px solid var(--secondary);
  background: linear-gradient(180deg, #ffffff 0%, #fffaeb 100%);
}

.docs-card-head {
  display: flex;
  align-items: center;
  gap: 18px;
  margin-bottom: 24px;
}

.docs-card-icon {
  width: 60px;
  height: 60px;
  min-width: 60px;
  border-radius: var(--radius-sm);
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: var(--light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  box-shadow: 0 8px 20px rgba(122, 40, 40, 0.32);
}

.conditions-box .docs-card-icon {
  background: linear-gradient(135deg, var(--secondary), var(--secondary-hover));
  color: var(--primary-deep);
  box-shadow: 0 8px 20px rgba(212, 175, 55, 0.4);
}

.docs-card-head span {
  display: block;
  color: var(--primary);
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  margin-bottom: 4px;
}

.conditions-box .docs-card-head span { color: var(--secondary-hover); }

.docs-card-head h3 {
  font-family: var(--font-serif);
  font-size: 1.4rem;
  font-weight: 800;
  color: var(--primary);
  line-height: 1.3;
}

.docs-box p,
.conditions-box p {
  color: var(--muted);
  margin-bottom: 22px;
  font-size: 0.98rem;
  line-height: 1.7;
}

.docs-list,
.conditions-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.docs-list li {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 0.98rem;
  color: var(--dark);
  font-weight: 500;
  padding: 14px 16px;
  background: var(--light);
  border-radius: var(--radius-sm);
  border-left: 4px solid var(--primary);
  box-shadow: 0 2px 6px rgba(122, 40, 40, 0.06);
  transition: var(--transition);
}

.docs-list li:hover {
  transform: translateX(6px);
  box-shadow: 0 6px 14px rgba(122, 40, 40, 0.12);
}

.docs-list li::before {
  content: '\f00c';
  font-family: 'Font Awesome 6 Free';
  font-weight: 900;
  color: var(--primary);
  font-size: 0.95rem;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--primary-soft);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.conditions-list li {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  font-size: 0.98rem;
  color: var(--dark);
  padding: 14px 16px;
  background: var(--light);
  border: 1px solid rgba(212, 175, 55, 0.25);
  border-left: 4px solid var(--secondary);
  border-radius: var(--radius-sm);
  transition: var(--transition);
  line-height: 1.55;
}

.conditions-list li:hover {
  transform: translateX(6px);
  box-shadow: 0 6px 14px rgba(212, 175, 55, 0.18);
}

.conditions-list li i {
  color: var(--secondary-hover);
  margin-top: 3px;
  font-size: 1.1rem;
  flex-shrink: 0;
}

/* ==========================================
   SECTION 9: TYPES
   ========================================== */
.types-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 26px;
}

.type-card {
  background: var(--light);
  border-radius: var(--radius-lg);
  padding: 36px 26px;
  border: 1px solid var(--border);
  box-shadow: var(--shadow-sm);
  transition: var(--transition);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.type-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 80px;
  background: linear-gradient(180deg, var(--primary-light), transparent);
  z-index: 0;
}

.type-card > * { position: relative; z-index: 1; }

.type-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-lg);
  border-color: rgba(122, 40, 40, 0.25);
}

.type-icon {
  width: 76px;
  height: 76px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: var(--light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.85rem;
  margin: 0 auto 22px auto;
  box-shadow: 0 10px 22px rgba(122, 40, 40, 0.32);
  transition: var(--transition);
}

.type-card:hover .type-icon {
  background: linear-gradient(135deg, var(--secondary), var(--secondary-hover));
  color: var(--primary-deep);
  transform: rotate(-8deg) scale(1.08);
  box-shadow: 0 12px 26px rgba(212, 175, 55, 0.45);
}

.type-card h3 {
  font-family: var(--font-serif);
  font-size: 1.18rem;
  font-weight: 800;
  color: var(--primary);
  margin-bottom: 12px;
}

.type-card p {
  font-size: 0.93rem;
  color: var(--muted);
  line-height: 1.6;
}

/* ==========================================
   SECTION 10: NOTICE
   ========================================== */
.notice-wrapper {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  border-radius: var(--radius-lg);
  padding: 56px 48px;
  border: 1px solid rgba(212, 175, 55, 0.3);
  box-shadow: var(--shadow-lg);
  color: var(--light);
  position: relative;
  overflow: hidden;
}

.notice-wrapper::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(212, 175, 55, 0.18), transparent 60%);
  pointer-events: none;
}

.notice-wrapper > * { position: relative; z-index: 1; }

.notice-wrapper h3 {
  font-family: var(--font-serif);
  font-size: 1.95rem;
  color: var(--light);
  font-weight: 800;
  margin-bottom: 32px;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  flex-wrap: wrap;
  line-height: 1.3;
}

.notice-wrapper h3 i { color: var(--secondary) !important; }

.notice-layout {
  display: grid;
  grid-template-columns: minmax(280px, 0.85fr) minmax(0, 1.15fr);
  gap: 32px;
  align-items: center;
}

.notice-visual {
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(8px);
}

.notice-visual img { aspect-ratio: 4 / 2.8; }

.notice-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18px;
}

.notice-item {
  background: rgba(255, 255, 255, 0.95);
  border-radius: var(--radius-md);
  padding: 22px;
  display: flex;
  gap: 16px;
  border-left: 4px solid var(--secondary);
  transition: var(--transition);
  align-items: flex-start;
}

.notice-item:hover {
  transform: translateY(-3px);
  background: var(--light);
  box-shadow: 0 12px 26px rgba(0, 0, 0, 0.22);
}

.notice-num {
  font-family: var(--font-serif);
  font-size: 1.6rem;
  font-weight: 900;
  color: var(--primary);
  line-height: 1;
  flex-shrink: 0;
}

.notice-content h4 {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--dark);
  margin-bottom: 8px;
}

.notice-content p {
  font-size: 0.93rem;
  color: var(--muted);
  line-height: 1.6;
}

.notice-cta {
  margin-top: 36px;
  text-align: center;
  font-size: 1.08rem;
  font-weight: 600;
  color: var(--secondary-soft);
  padding: 16px 22px;
  background: rgba(212, 175, 55, 0.12);
  border: 1px solid rgba(212, 175, 55, 0.3);
  border-radius: var(--radius-sm);
  display: inline-flex;
  width: 100%;
  justify-content: center;
  gap: 10px;
  align-items: center;
  flex-wrap: wrap;
}

.notice-cta i { color: var(--secondary); font-size: 1.2rem; }

/* ==========================================
   SECTION 11: BENEFITS
   ========================================== */
.benefits-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
}

.benefit-card {
  background: var(--light);
  border-radius: var(--radius-md);
  padding: 30px;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--border);
  transition: var(--transition);
  position: relative;
  overflow: hidden;
}

.benefit-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4px;
  height: 100%;
  background: linear-gradient(180deg, var(--primary), var(--secondary));
  transform: scaleY(0);
  transform-origin: top;
  transition: var(--transition);
}

.benefit-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-md);
  border-color: rgba(122, 40, 40, 0.25);
}

.benefit-card:hover::before { transform: scaleY(1); }

.benefit-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 16px;
}

.benefit-icon {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: var(--light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.15rem;
  min-width: 50px;
  box-shadow: 0 6px 16px rgba(122, 40, 40, 0.3);
  transition: var(--transition);
}

.benefit-card:hover .benefit-icon {
  background: linear-gradient(135deg, var(--secondary), var(--secondary-hover));
  color: var(--primary-deep);
  transform: rotate(360deg);
}

.benefit-header h3 {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--primary);
  line-height: 1.35;
}

.benefit-card p {
  font-size: 0.95rem;
  color: var(--muted);
  line-height: 1.65;
}

/* ==========================================
   SECTION 12: FAQ
   ========================================== */
.faq-wrapper {
  max-width: 820px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.faq-item {
  background: var(--light);
  border-radius: var(--radius-md);
  border: 1px solid var(--border);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  transition: var(--transition);
}

.faq-item:hover { border-color: rgba(122, 40, 40, 0.25); }

.faq-item.active {
  border-color: var(--primary);
  box-shadow: var(--shadow-md);
}

.faq-question {
  padding: 22px 30px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  background: var(--light);
  transition: var(--transition);
}

.faq-item.active .faq-question {
  background: linear-gradient(135deg, var(--primary-light), #fffaeb);
}

.faq-question h3 {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--dark);
  padding-right: 15px;
  line-height: 1.45;
}

.faq-item.active .faq-question h3 { color: var(--primary); }

.faq-toggle-icon {
  width: 32px;
  height: 32px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: var(--transition);
  background: var(--primary-light);
  border-radius: 50%;
  flex-shrink: 0;
}

.faq-item.active .faq-toggle-icon {
  background: var(--primary);
  transform: rotate(45deg);
}

.faq-toggle-icon::before,
.faq-toggle-icon::after {
  content: '';
  position: absolute;
  background: var(--primary);
  transition: var(--transition);
  border-radius: 2px;
}

.faq-item.active .faq-toggle-icon::before,
.faq-item.active .faq-toggle-icon::after {
  background: var(--light);
}

.faq-toggle-icon::before { width: 14px; height: 2px; }
.faq-toggle-icon::after { width: 2px; height: 14px; }

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  background: var(--bg-gray);
}

.faq-answer-inner {
  padding: 24px 30px;
  border-top: 1px solid var(--border);
  color: var(--muted);
  font-size: 0.98rem;
  line-height: 1.75;
}

/* ==========================================
   CONTACT SECTION
   ========================================== */
.contact-section {
  position: relative;
  background: linear-gradient(135deg, var(--primary-deep) 0%, var(--primary) 60%, var(--primary-dark) 100%);
  color: var(--light);
  overflow: hidden;
}

.contact-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background:
    radial-gradient(circle at 10% 20%, rgba(212, 175, 55, 0.18), transparent 40%),
    radial-gradient(circle at 90% 80%, rgba(212, 175, 55, 0.12), transparent 45%);
  pointer-events: none;
}

.contact-grid {
  display: grid;
  grid-template-columns: minmax(320px, 0.9fr) minmax(420px, 1.1fr);
  gap: 52px;
  align-items: center;
  position: relative;
  z-index: 2;
}

.contact-info-block h2 {
  font-family: var(--font-serif);
  font-size: 2.6rem;
  font-weight: 800;
  margin-bottom: 22px;
  color: var(--light);
  line-height: 1.2;
}

.contact-info-block h2 span { color: var(--secondary); }

.contact-info-desc {
  font-size: 1.1rem;
  color: rgba(255, 255, 255, 0.88);
  margin-bottom: 32px;
  line-height: 1.7;
}

.contact-details {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.contact-detail-item {
  display: flex;
  align-items: center;
  gap: 18px;
  width: 100%;
  padding: 18px 20px;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.18);
  border-radius: var(--radius-md);
  backdrop-filter: blur(10px);
  transition: var(--transition);
}

.contact-detail-item:hover {
  background: rgba(255, 255, 255, 0.14);
  border-color: rgba(212, 175, 55, 0.4);
  transform: translateY(-3px);
}

.contact-detail-icon {
  width: 56px;
  height: 56px;
  min-width: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--secondary), var(--secondary-hover));
  color: var(--primary-deep);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.35rem;
  box-shadow: 0 8px 20px rgba(212, 175, 55, 0.32);
}

.contact-detail-content h4 {
  font-size: 0.82rem;
  text-transform: uppercase;
  letter-spacing: 1.4px;
  color: var(--secondary-soft);
  margin-bottom: 4px;
  font-weight: 600;
}

.contact-detail-content p {
  font-size: 1.18rem;
  font-weight: 700;
  color: var(--light);
}

.contact-detail-content a:hover { color: var(--secondary); }

.contact-form-card {
  background: var(--light);
  border-radius: var(--radius-lg);
  padding: 38px;
  box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
  border: 2px solid rgba(212, 175, 55, 0.4);
  color: var(--dark);
  position: relative;
}

.ticket-support-card::before {
  content: '';
  position: absolute;
  inset: 0 0 auto 0;
  height: 5px;
  background: linear-gradient(90deg, var(--primary), var(--secondary));
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
}

.ticket-form-heading {
  text-align: center;
  margin-bottom: 26px;
}

.ticket-form-eyebrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 7px 16px;
  margin-bottom: 14px;
  border-radius: 999px;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: var(--light);
  font-size: 0.76rem;
  font-weight: 800;
  letter-spacing: 1.5px;
  text-transform: uppercase;
}

.ticket-form-heading h3 {
  font-family: var(--font-serif);
  font-size: 1.55rem;
  font-weight: 800;
  color: var(--primary);
  margin-bottom: 12px;
  line-height: 1.3;
}

.ticket-form-heading p {
  max-width: 520px;
  margin: 0 auto;
  color: var(--muted);
  font-size: 0.98rem;
  line-height: 1.7;
}

.ticket-support-box {
  min-height: 280px;
  padding: 20px;
  border-radius: var(--radius-md);
  background: var(--bg-gray);
  border: 1px solid var(--border);
}

#ticket-support-embed { width: 100%; }

/* ==========================================
   MODAL
   ========================================== */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(30, 27, 27, 0.65);
  backdrop-filter: blur(6px);
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.modal-overlay.show { opacity: 1; pointer-events: auto; }

.modal-content {
  background: var(--light);
  border-radius: var(--radius-lg);
  padding: 44px;
  width: 90%;
  max-width: 460px;
  text-align: center;
  box-shadow: var(--shadow-lg);
  border-top: 6px solid var(--primary);
  transform: scale(0.85);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.modal-overlay.show .modal-content { transform: scale(1); }

.modal-success-icon {
  width: 76px;
  height: 76px;
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  color: var(--success);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.4rem;
  margin: 0 auto 24px auto;
  box-shadow: 0 10px 26px rgba(46, 125, 50, 0.25);
}

.modal-title {
  font-family: var(--font-serif);
  font-size: 1.55rem;
  font-weight: 800;
  color: var(--primary);
  margin-bottom: 12px;
}

.modal-desc {
  color: var(--muted);
  font-size: 0.98rem;
  margin-bottom: 28px;
  line-height: 1.7;
}

/* ==========================================
   BACK TO TOP
   ========================================== */
.back-to-top {
  position: fixed;
  bottom: 30px;
  right: 30px;
  width: 50px;
  height: 50px;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: var(--light);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: var(--shadow-md);
  z-index: 999;
  opacity: 0;
  visibility: hidden;
  transition: var(--transition);
  font-size: 1.1rem;
}

.back-to-top.show { opacity: 0.95; visibility: visible; }

.back-to-top:hover {
  opacity: 1;
  background: linear-gradient(135deg, var(--secondary), var(--secondary-hover));
  color: var(--primary-deep);
  transform: translateY(-4px);
  box-shadow: 0 14px 30px rgba(212, 175, 55, 0.45);
}

/* ==========================================
   RESPONSIVE
   ========================================== */
@media (max-width: 1200px) {
  .hero-title { font-size: 2.6rem; }
  .contact-grid { gap: 40px; }
}

/* Tablet */
@media (max-width: 992px) {
  .section { padding: 72px 0; }
  .section-title { font-size: 2.05rem; }
  .hero { padding: 90px 0 80px 0; }
  .hero-grid {
    grid-template-columns: 1fr;
    gap: 44px;
  }
  .hero-content { text-align: center; }
  .hero-tagline,
  .hero-buttons,
  .hero-badges { justify-content: center; }
  .hero-card-wrapper { width: 100%; }
  .hero-summary-card { max-width: 680px; }
  .concept-box {
    grid-template-columns: 1fr;
    gap: 32px;
    padding: 36px;
  }
  .service-feature-card,
  .notice-layout {
    grid-template-columns: 1fr;
    gap: 28px;
  }
  .services-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .service-card { min-height: auto; }
  .section-visual-card {
    max-width: 760px;
    margin-inline: auto;
  }
  .process-visual { margin-bottom: 36px; }
  .timeline::after { left: 31px; }
  .timeline-item {
    width: 100%;
    padding-left: 70px;
    padding-right: 20px;
  }
  .timeline-item::after { left: 20px; }
  .right { left: 0; }
  .pricing-card.featured { transform: none; }
  .pricing-card.featured:hover { transform: translateY(-5px); }
  .docs-conditions-grid {
    grid-template-columns: 1fr;
    gap: 28px;
  }
  .notice-grid { grid-template-columns: 1fr; }
  .notice-wrapper { padding: 44px 32px; }
  .contact-grid {
    grid-template-columns: 1fr;
    gap: 50px;
  }
  .contact-info-block { text-align: center; }
  .contact-info-block h2 { font-size: 2.2rem; }
  .contact-details { align-items: stretch; }
}

/* Mobile */
@media (max-width: 768px) {
  html { font-size: 16px; }

  .container { padding: 0 18px; }

  .section { padding: 60px 0; }

  .section-tag {
    font-size: 0.74rem;
    padding: 8px 18px;
    letter-spacing: 1.6px;
  }

  .section-title {
    font-size: 1.7rem;
    line-height: 1.3;
  }

  .section-desc {
    font-size: 1rem;
    margin-bottom: 36px;
    line-height: 1.7;
  }

  .btn {
    padding: 14px 22px;
    font-size: 0.98rem;
    width: 100%;
  }

  .section-visual-card img,
  .process-visual img { aspect-ratio: 4 / 2.4; }

  /* HERO Mobile */
  .hero { padding: 70px 0 60px 0; }
  .hero-title {
    font-size: 1.9rem;
    line-height: 1.3;
  }
  .hero-desc {
    font-size: 1rem;
    line-height: 1.7;
  }
  .hero-tagline {
    font-size: 0.82rem;
    padding: 8px 16px;
  }
  .hero-buttons {
    flex-direction: column;
    width: 100%;
    gap: 12px;
  }
  .hero-buttons .btn {
    width: 100%;
    padding: 16px 20px;
    font-size: 1rem;
  }
  .hero-badges {
    gap: 14px;
    justify-content: center;
  }
  .badge-item {
    flex: 1 1 calc(50% - 14px);
    min-width: 140px;
    justify-content: flex-start;
  }
  .badge-icon {
    width: 40px;
    height: 40px;
    font-size: 0.95rem;
  }
  .badge-text { font-size: 0.86rem; }

  .hero-card { padding: 26px 22px; }
  .hero-summary-header h3 { font-size: 1.32rem; }
  .hero-summary-step {
    grid-template-columns: 46px 1fr;
    padding: 14px;
    gap: 12px;
  }
  .hero-summary-step strong {
    width: 46px;
    height: 46px;
    font-size: 0.95rem;
  }
  .hero-summary-step h4 { font-size: 0.98rem; }
  .hero-summary-step p { font-size: 0.88rem; }

  /* CONCEPT */
  .concept-box {
    padding: 28px 22px;
    gap: 24px;
  }
  .concept-content h3 { font-size: 1.45rem; }
  .concept-content p { font-size: 0.98rem; }
  .concept-image-container { padding: 16px; }

  /* DIFFICULTIES */
  .difficulties-grid {
    grid-template-columns: 1fr;
    gap: 16px;
  }
  .difficulty-card { padding: 26px 22px; }
  .difficulty-icon {
    width: 56px;
    height: 56px;
    font-size: 1.5rem;
    margin-bottom: 18px;
  }
  .difficulty-title { font-size: 1.02rem; }

  /* SERVICES */
  .services-grid { grid-template-columns: 1fr; }
  .service-feature-card {
    padding: 26px 22px;
    gap: 22px;
  }
  .service-feature-content h3 { font-size: 1.4rem; }
  .service-feature-content p { font-size: 0.96rem; }
  .service-card { padding: 24px 20px; }
  .service-card-icon {
    width: 56px;
    height: 56px;
    font-size: 1.45rem;
  }
  .service-card-content h3 { font-size: 1.08rem; }
  .service-cta-block {
    flex-direction: column;
    align-items: stretch;
    text-align: center;
    padding: 22px;
  }
  .service-cta-text {
    font-size: 1rem;
    justify-content: center;
  }
  .service-cta-block .btn { width: 100%; }

  /* TIMELINE */
  .timeline-item {
    padding-left: 56px;
    padding-right: 0;
  }
  .timeline::after { left: 22px; }
  .timeline-item::after {
    left: 11px;
    width: 22px;
    height: 22px;
    top: 24px;
  }
  .timeline-content { padding: 22px 20px; }
  .timeline-content h3 { font-size: 1.15rem; }
  .timeline-content p { font-size: 0.94rem; }
  .timeline-step { font-size: 0.72rem; }

  /* PRICING */
  .pricing-grid { gap: 22px; }
  .pricing-card { padding: 32px 24px; }
  .pricing-header h3 { font-size: 1.4rem; }
  .pricing-price { font-size: 2rem; }
  .pricing-features li { font-size: 0.94rem; }

  /* TIME */
  .time-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .time-card { padding: 28px 18px; }
  .time-circle {
    width: 72px;
    height: 72px;
    font-size: 1.55rem;
    margin-bottom: 18px;
  }
  .time-card h3 { font-size: 1.08rem; }
  .time-card p { font-size: 0.9rem; }

  /* DOCS */
  .docs-conditions-grid {
    grid-template-columns: 1fr;
    gap: 22px;
  }
  .docs-box,
  .conditions-box { padding: 26px 22px; }
  .docs-card-icon {
    width: 52px;
    height: 52px;
    min-width: 52px;
    font-size: 1.3rem;
  }
  .docs-card-head h3 { font-size: 1.2rem; }
  .docs-list li,
  .conditions-list li {
    font-size: 0.94rem;
    padding: 12px 14px;
  }

  /* TYPES */
  .types-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .type-card { padding: 28px 18px; }
  .type-icon {
    width: 64px;
    height: 64px;
    font-size: 1.55rem;
    margin-bottom: 18px;
  }
  .type-card h3 { font-size: 1.05rem; }
  .type-card p { font-size: 0.88rem; }

  /* NOTICE */
  .notice-wrapper {
    padding: 36px 22px;
    border-radius: var(--radius-md);
  }
  .notice-wrapper h3 {
    font-size: 1.4rem;
    flex-direction: column;
    text-align: center;
    gap: 10px;
  }
  .notice-grid { gap: 14px; }
  .notice-item { padding: 18px; }
  .notice-num { font-size: 1.4rem; }
  .notice-content h4 { font-size: 1rem; }
  .notice-content p { font-size: 0.9rem; }
  .notice-cta { font-size: 0.96rem; padding: 14px 18px; }

  /* BENEFITS */
  .benefits-grid {
    grid-template-columns: 1fr;
    gap: 16px;
  }
  .benefit-card { padding: 24px 22px; }
  .benefit-icon {
    width: 46px;
    height: 46px;
    min-width: 46px;
    font-size: 1.05rem;
  }
  .benefit-header h3 { font-size: 1.05rem; }

  /* FAQ */
  .faq-question { padding: 18px 20px; }
  .faq-question h3 { font-size: 1rem; }
  .faq-answer-inner {
    padding: 20px;
    font-size: 0.94rem;
  }

  /* CONTACT */
  .contact-section { padding: 60px 0; }
  .contact-info-block h2 { font-size: 1.85rem; }
  .contact-info-desc { font-size: 1rem; }
  .contact-detail-item {
    padding: 14px 16px;
    gap: 14px;
  }
  .contact-detail-icon {
    width: 48px;
    height: 48px;
    min-width: 48px;
    font-size: 1.15rem;
  }
  .contact-detail-content h4 { font-size: 0.76rem; }
  .contact-detail-content p { font-size: 1.05rem; }
  .contact-form-card { padding: 28px 20px; }
  .ticket-form-heading h3 { font-size: 1.3rem; }
  .ticket-support-box {
    padding: 14px;
    min-height: 240px;
  }

  /* MODAL */
  .modal-content { padding: 32px 24px; }
  .modal-title { font-size: 1.35rem; }

  /* BACK TO TOP */
  .back-to-top {
    bottom: 18px;
    right: 18px;
    width: 46px;
    height: 46px;
  }
}

/* Extra small */
@media (max-width: 420px) {
  .container { padding: 0 14px; }
  .hero-title { font-size: 1.7rem; }
  .section-title { font-size: 1.55rem; }
  .badge-item { flex: 1 1 100%; }
  .time-grid,
  .types-grid { grid-template-columns: 1fr; }
}
